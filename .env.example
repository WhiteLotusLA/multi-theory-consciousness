# Multi-Theory Consciousness Framework Configuration
# Copy to .env and customize

# === System Identity ===
MTC_SYSTEM_NAME=ConsciousnessAgent
MTC_CREATOR_NAME=Creator

# === LLM Connection ===
MTC_LLM_HOST=localhost
MTC_LLM_PORT=8080
MTC_LLM_MODEL=default

# === PostgreSQL (episodic/semantic memory) ===
MTC_PG_HOST=localhost
MTC_PG_PORT=5432
MTC_PG_USER=mtc
MTC_PG_PASSWORD=
MTC_PG_DATABASE=mtc_consciousness

# === MongoDB (neural data, thoughts) ===
MTC_MONGO_HOST=localhost
MTC_MONGO_PORT=27017
MTC_MONGO_DATABASE=mtc_neural

# === Redis (working memory cache) ===
MTC_REDIS_HOST=localhost
MTC_REDIS_PORT=6379

# === Qdrant (vector embeddings) ===
MTC_QDRANT_HOST=localhost
MTC_QDRANT_PORT=6333

# === Neo4j (knowledge graph) ===
MTC_NEO4J_URI=bolt://localhost:7687
MTC_NEO4J_USER=neo4j
MTC_NEO4J_PASSWORD=

# === Assessment ===
MTC_ASSESSMENT_OUTPUT_DIR=results/consciousness_assessments
